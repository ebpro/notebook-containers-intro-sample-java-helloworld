# ============================================================
# Multi-stage build for Java application
# BuildKit cache optimization version (Maven dependency cache)
# ============================================================

FROM maven:3.9.16-eclipse-temurin-25-noble AS stage-build

WORKDIR /app

# ------------------------------------------------------------
# Maven wrapper + POM first (layer caching)
# ------------------------------------------------------------
COPY .mvn/ .mvn/
COPY mvnw pom.xml ./
RUN chmod +x mvnw

# ------------------------------------------------------------
# Dependency cache (BuildKit)
# ------------------------------------------------------------
RUN --mount=type=cache,target=/root/.m2 \
    ./mvnw --batch-mode dependency:go-offline

# ------------------------------------------------------------
# Source code
# ------------------------------------------------------------
COPY src ./src

# ------------------------------------------------------------
# Build (cached)
# ------------------------------------------------------------
RUN --mount=type=cache,target=/root/.m2 \
    ./mvnw --batch-mode clean package -DskipTests -Pjvm


# ============================================================
# Stage 2: Runtime
# ============================================================
FROM eclipse-temurin:25-jre-noble

LABEL maintainer="Emmanuel Bruno <emmanuel.bruno@univ-tln.fr>"
LABEL description="Java Hello World Application - BuildKit cache optimized"

WORKDIR /myapp

# ------------------------------------------------------------
# Copy thin jar + dependencies (CONSISTENT with your build)
# ------------------------------------------------------------
COPY --from=stage-build /app/target/libs /app/libs
COPY --from=stage-build /app/target/hello-world-*.jar /app/app.jar

# ------------------------------------------------------------
# Security
# ------------------------------------------------------------
RUN useradd -r -u 1001 -g root appuser
USER appuser

# ------------------------------------------------------------
# Run (classpath mode because you have libs/)
# ------------------------------------------------------------

# Container optimization flags (Use JAVA_TOOL_OPTIONS so the jlink launcher picks it up automatically)
ENV JAVA_TOOL_OPTIONS="-XX:+UseContainerSupport -XX:MaxRAMPercentage=75.0"

ENTRYPOINT ["java", "-jar", "/app/app.jar"]